{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Layout Config",
  "description": "Configuration for CSS Grid layouts",
  "$ref": "#/$defs/gridConfig",
  "$defs": {
    "trackUnit": {
      "type": "string",
      "enum": ["fr", "px", "auto", "rem", "%", "min-content", "max-content"]
    },
    "gapUnit": {
      "type": "string",
      "enum": ["px", "rem", "%"]
    },
    "gridConfig": {
      "type": "object",
      "properties": {
        "type": { "const": "grid" },
        "areas": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "2D array of area names (grid-template-areas). Use '.' for empty cells."
        },
        "columns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of CSS track-size strings for grid-template-columns"
        },
        "rows": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of CSS track-size strings for grid-template-rows"
        },
        "gridWidth": {
          "type": "string",
          "description": "Container width CSS value"
        },
        "gridHeight": {
          "type": "string",
          "description": "Container height CSS value"
        },
        "rowGap": { "type": "number", "minimum": 0 },
        "rowGapUnit": { "$ref": "#/$defs/gapUnit" },
        "colGap": { "type": "number", "minimum": 0 },
        "colGapUnit": { "$ref": "#/$defs/gapUnit" }
      },
      "required": ["type", "areas", "columns", "rows"],
      "additionalProperties": false
    }
  }
}
