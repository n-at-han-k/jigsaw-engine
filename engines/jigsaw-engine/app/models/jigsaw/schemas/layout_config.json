{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Layout Config",
  "description": "Configuration for CSS Grid or Flexbox layouts",
  "oneOf": [
    { "$ref": "#/$defs/gridConfig" },
    { "$ref": "#/$defs/flexConfig" }
  ],
  "$defs": {
    "trackUnit": {
      "type": "string",
      "enum": ["fr", "px", "auto", "rem", "%", "min-content", "max-content"]
    },
    "gapUnit": {
      "type": "string",
      "enum": ["px", "rem", "%"]
    },
    "track": {
      "type": "object",
      "properties": {
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/trackUnit" }
      },
      "required": ["value", "unit"],
      "additionalProperties": false
    },
    "trackRepeat": {
      "type": "object",
      "properties": {
        "repeat": {
          "type": "string",
          "enum": ["auto-fit", "auto-fill"]
        },
        "value": { "type": "number" },
        "unit": { "$ref": "#/$defs/trackUnit" }
      },
      "required": ["repeat", "value", "unit"],
      "additionalProperties": false
    },
    "tracks": {
      "oneOf": [
        {
          "type": "array",
          "items": { "$ref": "#/$defs/track" },
          "minItems": 1
        },
        { "$ref": "#/$defs/trackRepeat" }
      ]
    },
    "gridContainerAlignment": {
      "type": "object",
      "properties": {
        "horizontal": {
          "type": "string",
          "enum": ["stretch", "start", "end", "center", "space-between", "space-around", "space-evenly"]
        },
        "vertical": {
          "type": "string",
          "enum": ["stretch", "start", "end", "center", "space-between", "space-around", "space-evenly"]
        }
      },
      "required": ["horizontal", "vertical"],
      "additionalProperties": false
    },
    "gridChildrenAlignment": {
      "type": "object",
      "properties": {
        "horizontal": {
          "type": "string",
          "enum": ["stretch", "start", "end", "center"]
        },
        "vertical": {
          "type": "string",
          "enum": ["stretch", "start", "end", "center"]
        }
      },
      "required": ["horizontal", "vertical"],
      "additionalProperties": false
    },
    "flexContainerAlignment": {
      "type": "object",
      "properties": {
        "mainAxis": {
          "type": "string",
          "enum": ["flex-start", "flex-end", "center", "space-between", "space-around", "space-evenly"]
        },
        "crossAxis": {
          "type": "string",
          "enum": ["stretch", "flex-start", "flex-end", "center", "baseline"]
        }
      },
      "required": ["mainAxis", "crossAxis"],
      "additionalProperties": false
    },
    "flexChild": {
      "type": "object",
      "properties": {
        "grow": { "type": "number" },
        "shrink": { "type": "number" },
        "basis": { "type": "string" },
        "margin": { "type": "boolean" }
      },
      "required": ["grow", "shrink", "basis", "margin"],
      "additionalProperties": false
    },
    "gridChildPlacement": {
      "type": "object",
      "properties": {
        "row": {
          "type": "string",
          "description": "grid-row value, e.g. '1 / -1', '2 / span 2'"
        },
        "column": {
          "type": "string",
          "description": "grid-column value, e.g. '1 / -1', '1 / 3'"
        }
      },
      "additionalProperties": false
    },
    "gridConfig": {
      "type": "object",
      "properties": {
        "type": { "const": "grid" },
        "childrenCount": {
          "type": "integer",
          "minimum": 1
        },
        "rows": { "$ref": "#/$defs/tracks" },
        "columns": { "$ref": "#/$defs/tracks" },
        "rowGap": { "type": "number", "minimum": 0 },
        "rowGapUnit": { "$ref": "#/$defs/gapUnit" },
        "colGap": { "type": "number", "minimum": 0 },
        "colGapUnit": { "$ref": "#/$defs/gapUnit" },
        "areas": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": "2D array of area names (grid-template-areas). Use '.' for empty cells."
        },
        "gridAreasMode": {
          "type": "string",
          "enum": ["names", "line numbers"],
          "description": "Whether grid areas use named areas or line-number-based placements"
        },
        "direction": {
          "type": "string",
          "enum": ["row", "column"],
          "description": "grid-auto-flow direction"
        },
        "emptySpace": {
          "type": "string",
          "enum": ["dont-fill", "fill"],
          "description": "Whether to fill empty grid cells (maps to grid-auto-flow: dense)"
        },
        "containerAlignment": {
          "$ref": "#/$defs/gridContainerAlignment",
          "description": "Container alignment (justify-content / align-content)"
        },
        "childrenAlignment": {
          "$ref": "#/$defs/gridChildrenAlignment",
          "description": "Children alignment (justify-items / align-items)"
        },
        "childPlacements": {
          "type": "array",
          "items": { "$ref": "#/$defs/gridChildPlacement" },
          "description": "Per-child grid-row/grid-column placement via line numbers"
        }
      },
      "required": ["type", "childrenCount", "columns", "rowGap", "rowGapUnit", "colGap", "colGapUnit"],
      "additionalProperties": false
    },
    "flexConfig": {
      "type": "object",
      "properties": {
        "type": { "const": "flex" },
        "childrenCount": {
          "type": "integer",
          "minimum": 1
        },
        "direction": {
          "type": "string",
          "enum": ["row", "column", "row-reverse", "column-reverse"]
        },
        "wrap": {
          "type": "string",
          "enum": ["nowrap", "wrap", "wrap-reverse"]
        },
        "gap": { "type": "number", "minimum": 0 },
        "gapUnit": { "$ref": "#/$defs/gapUnit" },
        "containerAlignment": {
          "$ref": "#/$defs/flexContainerAlignment",
          "description": "Container alignment (justify-content / align-items)"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/flexChild" },
          "description": "Per-child flex properties (grow, shrink, basis, margin)"
        }
      },
      "required": ["type", "childrenCount", "direction", "gap", "gapUnit"],
      "additionalProperties": false
    }
  }
}
